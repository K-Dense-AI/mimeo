# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Parallel: https://platform.parallel.ai/
PARALLEL_API_KEY=...

# Optional: override the default model (any OpenRouter model slug works)
# MIMEO_MODEL=google/gemini-3.1-pro-preview

# Optional: HTTP-Referer + X-Title headers OpenRouter uses for attribution
# OPENROUTER_SITE_URL=https://github.com/you/mimeo
# OPENROUTER_APP_NAME=mimeo
