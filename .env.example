# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Direct LLM providers (optional; set the one you select with --llm-provider)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# Parallel: https://platform.parallel.ai/
PARALLEL_API_KEY=...

# Optional: provider selection. Defaults preserve historical behavior.
# MIMEO_LLM_PROVIDER=openrouter
# MIMEO_SEARCH_PROVIDER=parallel
# MIMEO_IMAGE_PROVIDER=openrouter

# Optional: override the default model. For direct providers, use a native model id.
# MIMEO_MODEL=google/gemini-3.1-pro-preview
# MIMEO_OPENAI_MODEL=gpt-5.4
# MIMEO_ANTHROPIC_MODEL=claude-opus-4-5
# MIMEO_XAI_MODEL=grok-4
# MIMEO_GOOGLE_MODEL=gemini-3-pro

# Optional: HTTP-Referer + X-Title headers OpenRouter uses for attribution
# OPENROUTER_SITE_URL=https://github.com/you/mimeo
# OPENROUTER_APP_NAME=mimeo

# Optional: avatar image model when MIMEO_IMAGE_PROVIDER=openrouter
# MIMEO_AVATAR_MODEL=openai/gpt-5.4-image-2
